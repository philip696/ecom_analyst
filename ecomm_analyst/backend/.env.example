# Copy to .env and fill in values (run uvicorn from this backend/ directory).
DATABASE_URL=sqlite:///./ecommerce.db
SECRET_KEY=dev-secret-change-me

# Browser origin(s) for your Next app — must match where you open the UI (scheme+host+port).
FRONTEND_URL=http://localhost:3000

# Optional: comma-separated extra CORS origins. If unset, FRONTEND_URL + localhost:3000 are allowed.
# ALLOWED_CORS_ORIGINS=https://my-app.pages.dev,http://localhost:3001

# AI Insights (Deepseek — OpenAI-compatible). Get a key at https://platform.deepseek.com
LLM_API_KEY=
# Or use: OPENAI_API_KEY=  (legacy name, same as LLM_API_KEY)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Optional
OPENAI_API_KEY=
